# Hub (dashboard central pe hosting)
SECURITY_API_TOKEN=schimba-acest-token-secret
# Cont panou (creat automat la primul start dacă lipsește)
PANEL_ADMIN_USERNAME=admin
PANEL_ADMIN_PASSWORD=schimba-parola-admin
PANEL_SESSION_HOURS=24
PANEL_TOTP_ISSUER=NeoHost Security
DATABASE_URL=postgresql://user:pass@localhost:5432/neohost
# MySQL:    mysql+pymysql://user:pass@localhost:3306/neohost
# MariaDB:  mariadb+pymysql://user:pass@localhost:3306/neohost
ABUSEIPDB_API_KEY=
# Bot Telegram — creați la @BotFather, aceleași funcții ca dashboard-ul
TELEGRAM_BOT_TOKEN=
# URL public Mini App (ex: https://security.domeniu.md/telegram.html)
TELEGRAM_WEBAPP_URL=
HOST=127.0.0.1
PORT=7654
